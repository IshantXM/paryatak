# Paryatak API Environment Configuration
# Copy this to .env and fill in your values

PORT=4000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/paryatak?schema=public"

# JWT Secrets — change in production!
JWT_SECRET=paryatak-dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=paryatak-dev-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Redis (optional — app falls back to in-memory if not available)
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# Cloudinary — get free account at cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20
