{
  "name": "paryatak-api",
  "version": "1.0.0",
  "description": "Paryatak Tourism Platform — REST API with Express, Prisma (PostgreSQL), JWT Auth, Redis caching, Cloudinary uploads",
  "license": "ISC",
  "type": "commonjs",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
